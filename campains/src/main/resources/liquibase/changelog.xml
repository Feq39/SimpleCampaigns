        <insert tableName="emerald_accounts">
            <column name="seller_id"
                    valueComputed="(SELECT id FROM sellers WHERE name = 'seller_one')"/>
            <column name="funds" valueNumeric="1000.00"/>
        </insert>

        <insert tableName="emerald_accounts">
            <column name="seller_id"
                    valueComputed="(SELECT id FROM sellers WHERE name = 'seller_two')"/>
            <column name="funds" valueNumeric="750.00"/>
