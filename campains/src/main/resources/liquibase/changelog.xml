        <insert tableName="towns">
            <column name="name" value="Warszawa"/>
        </insert>

        <insert tableName="towns">
            <column name="name" value="Kraków"/>
        </insert>

        <insert tableName="towns">
            <column name="name" value="Wrocław"/>
        </insert>

        <insert tableName="towns">
            <column name="name" value="Poznań"/>
        </insert>

        <insert tableName="towns">
            <column name="name" value="Gdańsk"/>
        </insert>

        <insert tableName="keywords">
            <column name="keyword_value" value="electronics"/>
        </insert>

        <insert tableName="keywords">
            <column name="keyword_value" value="fashion"/>
        </insert>

        <insert tableName="keywords">
            <column name="keyword_value" value="home"/>
        </insert>

        <insert tableName="keywords">
            <column name="keyword_value" value="sports"/>
        </insert>

        <insert tableName="keywords">
            <column name="keyword_value" value="automotive"/>
        </insert>

        <insert tableName="keywords">
            <column name="keyword_value" value="garden"/>
        </insert>

        <insert tableName="keywords">
            <column name="keyword_value" value="beauty"/>
        </insert>

        <insert tableName="keywords">
            <column name="keyword_value" value="books"/>
        </insert>

        <insert tableName="keywords">
            <column name="keyword_value" value="toys"/>
        </insert>

        <insert tableName="keywords">
            <column name="keyword_value" value="sale"/>
        </insert>
    </changeSet>

</databaseChangeLog>